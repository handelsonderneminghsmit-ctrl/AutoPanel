<!DOCTYPE html>
<html lang="nl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AutoPanel — Beheer</title>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=DM+Sans:wght@400;500&family=DM+Mono:wght@400&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
:root{--bg:#07090f;--surface:#0e1018;--surface2:#141720;--border:#1e2338;--border2:#272d42;--text:#eef0f6;--text2:#6b7494;--text3:#3a4060;--accent:#e8f03c;--green:#3ce890;--red:#e83c6a;--orange:#f0923c;--blue:#3cb4e8}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh}

/* GATE */
#gate{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:20px;position:relative;overflow:hidden}
#gate::before{content:'';position:fixed;inset:0;background-image:linear-gradient(var(--border) 1px,transparent 1px),linear-gradient(90deg,var(--border) 1px,transparent 1px);background-size:48px 48px;opacity:.3;pointer-events:none}
#gate::after{content:'';position:fixed;top:-10%;left:50%;transform:translateX(-50%);width:500px;height:300px;background:radial-gradient(ellipse,rgba(232,60,106,.06) 0%,transparent 70%);pointer-events:none}
.gate-card{width:100%;max-width:380px;background:var(--surface);border:1px solid var(--border);padding:36px 32px;position:relative;z-index:1;animation:up .35s cubic-bezier(.4,0,.2,1);box-shadow:0 8px 32px rgba(0,0,0,.5)}
@keyframes up{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}
.g-logo{display:flex;align-items:center;gap:9px;justify-content:center;margin-bottom:6px}
.g-mark{width:34px;height:34px;background:var(--accent);display:flex;align-items:center;justify-content:center;font-family:'Outfit',sans-serif;font-weight:800;font-size:12px;color:#000}
.g-name{font-family:'Outfit',sans-serif;font-weight:700;font-size:16px}
.g-badge{display:inline-block;background:rgba(232,60,106,.1);border:1px solid rgba(232,60,106,.2);color:var(--red);font-size:9px;font-family:'DM Mono',monospace;padding:2px 8px;letter-spacing:.6px;text-transform:uppercase;margin:10px 0 20px}
.g-title{font-family:'Outfit',sans-serif;font-weight:700;font-size:19px;margin-bottom:5px}
.g-sub{font-size:13px;color:var(--text2);margin-bottom:22px;line-height:1.5}
.g-field{margin-bottom:12px}
.g-label{display:block;font-size:11.5px;font-weight:500;color:var(--text2);margin-bottom:5px}
.g-input{width:100%;background:var(--surface2);border:1px solid var(--border);padding:9px 13px;color:var(--text);font-family:'DM Sans',sans-serif;font-size:14px;outline:none;border-radius:2px;transition:border-color .15s}
.g-input:focus{border-color:var(--red)}
.g-input::placeholder{color:var(--text3)}
.g-err{font-size:12px;color:var(--red);margin-top:9px;padding:9px 12px;background:rgba(232,60,106,.08);border:1px solid rgba(232,60,106,.2);display:none}
.g-err.show{display:block}
.g-btn{width:100%;padding:11px;margin-top:8px;background:var(--red);color:#fff;font-family:'Outfit',sans-serif;font-weight:700;font-size:14px;border:none;cursor:pointer;border-radius:2px;transition:background .15s}
.g-btn:hover{background:#c02550}
.g-btn:disabled{background:var(--border2);cursor:not-allowed}
.g-foot{margin-top:16px;text-align:center;font-size:11px;color:var(--text3)}

/* PANEL */
#panel{display:none}
.topbar{height:52px;background:var(--surface);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 22px;gap:10px;position:sticky;top:0;z-index:100}
.t-logo{display:flex;align-items:center;gap:8px}
.t-mark{width:27px;height:27px;background:var(--accent);display:flex;align-items:center;justify-content:center;font-family:'Outfit',sans-serif;font-weight:800;font-size:11px;color:#000}
.t-name{font-family:'Outfit',sans-serif;font-weight:700;font-size:14px}
.t-badge{background:rgba(232,60,106,.1);border:1px solid rgba(232,60,106,.2);color:var(--red);font-size:9px;font-family:'DM Mono',monospace;padding:2px 6px;letter-spacing:.6px;text-transform:uppercase}
.t-url{font-family:'DM Mono',monospace;font-size:10px;color:var(--text3)}
.t-sp{flex:1}
.t-user{display:flex;align-items:center;gap:8px}
.t-av{width:27px;height:27px;background:var(--red);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:#fff;font-family:'Outfit',sans-serif}
.t-uname{font-size:12.5px;font-weight:500}
.t-out{background:none;border:1px solid var(--border);color:var(--text2);padding:4px 9px;font-size:11.5px;cursor:pointer;font-family:'DM Sans',sans-serif;border-radius:2px;transition:all .15s}
.t-out:hover{border-color:var(--border2);color:var(--text)}

.content{padding:22px;max-width:1080px;margin:0 auto}

/* KPI */
.kpi-row{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:20px}
.kpi{background:var(--surface);border:1px solid var(--border);padding:17px 19px;position:relative;overflow:hidden}
.kpi::after{content:'';position:absolute;top:0;left:0;right:0;height:2px}
.kpi.y::after{background:var(--accent)}.kpi.g::after{background:var(--green)}.kpi.r::after{background:var(--red)}.kpi.b::after{background:var(--blue)}
.kpi-lbl{font-size:11px;font-weight:500;color:var(--text3);text-transform:uppercase;letter-spacing:.3px;margin-bottom:7px}
.kpi-val{font-family:'Outfit',sans-serif;font-weight:700;font-size:34px;letter-spacing:-1px;line-height:1}
.kpi-sub{font-size:11.5px;color:var(--text2);margin-top:5px}

/* Panel */
.panel{background:var(--surface);border:1px solid var(--border);margin-bottom:14px}
.ph{padding:13px 17px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap}
.pt{font-family:'Outfit',sans-serif;font-weight:700;font-size:14px}
.pm{font-family:'DM Mono',monospace;font-size:10px;color:var(--text3)}
.search-wrap{display:flex;gap:7px;align-items:center;flex-wrap:wrap}
.sbox{display:flex;align-items:center;gap:7px;background:var(--surface2);border:1px solid var(--border);padding:6px 11px;min-width:190px}
.sbox input{background:none;border:none;outline:none;color:var(--text);font-family:'DM Sans',sans-serif;font-size:13px;width:100%}
.sbox input::placeholder{color:var(--text3)}
.pill{padding:5px 11px;border:1px solid var(--border);background:var(--surface2);color:var(--text2);font-size:12px;cursor:pointer;border-radius:20px;transition:all .15s;white-space:nowrap;user-select:none}
.pill:hover{color:var(--text)}.pill.active{border-color:var(--accent);color:var(--accent);background:rgba(232,240,60,.06)}

/* Table */
.tw{overflow-x:auto}
.ut{width:100%;border-collapse:collapse}
.ut th{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.3px;color:var(--text3);padding:9px 15px;text-align:left;border-bottom:2px solid var(--border);background:var(--surface2);white-space:nowrap}
.ut td{padding:12px 15px;font-size:13.5px;border-bottom:1px solid var(--border);color:var(--text2);vertical-align:middle}
.ut tr:last-child td{border-bottom:none}
.ut tr:hover td{background:var(--surface2)}
.td-name{color:var(--text);font-weight:600;font-size:14px}
.td-co{color:var(--text);font-weight:500}
.td-date{font-family:'DM Mono',monospace;font-size:11px;color:var(--text3)}

/* Badges */
.badge{display:inline-flex;align-items:center;gap:4px;padding:3px 10px;font-size:11px;font-weight:600;border-radius:20px;white-space:nowrap}
.badge::before{content:'';width:5px;height:5px;border-radius:50%;flex-shrink:0}
.bp{background:rgba(232,240,60,.1);color:var(--accent);border:1px solid rgba(232,240,60,.2)}.bp::before{background:var(--accent)}
.ba{background:rgba(60,232,144,.1);color:var(--green);border:1px solid rgba(60,232,144,.2)}.ba::before{background:var(--green)}
.br{background:rgba(232,60,106,.1);color:var(--red);border:1px solid rgba(232,60,106,.2)}.br::before{background:var(--red)}

/* Action btns */
.acts{display:flex;gap:5px}
.b-app{padding:5px 11px;background:rgba(60,232,144,.1);border:1px solid rgba(60,232,144,.25);color:var(--green);font-size:12px;font-weight:600;cursor:pointer;border-radius:2px;font-family:'DM Sans',sans-serif;transition:all .15s;white-space:nowrap}
.b-app:hover{background:rgba(60,232,144,.2)}
.b-rev{padding:5px 11px;background:rgba(232,60,106,.08);border:1px solid rgba(232,60,106,.2);color:var(--red);font-size:12px;font-weight:600;cursor:pointer;border-radius:2px;font-family:'DM Sans',sans-serif;transition:all .15s;white-space:nowrap}
.b-rev:hover{background:rgba(232,60,106,.18)}
.b-del{padding:5px 8px;background:transparent;border:1px solid var(--border);color:var(--text3);font-size:12px;cursor:pointer;border-radius:2px;font-family:'DM Sans',sans-serif;transition:all .15s}
.b-del:hover{border-color:var(--red);color:var(--red)}
.empty{padding:40px 20px;text-align:center;color:var(--text3);font-size:13px}

/* Modal */
.mback{display:none;position:fixed;inset:0;background:rgba(7,9,15,.85);z-index:500;align-items:center;justify-content:center;padding:20px}
.mback.open{display:flex}
.modal{background:var(--surface);border:1px solid var(--border);width:100%;max-width:370px;padding:26px;box-shadow:0 8px 32px rgba(0,0,0,.5);animation:up .2s}
.m-title{font-family:'Outfit',sans-serif;font-weight:700;font-size:17px;margin-bottom:7px}
.m-text{font-size:13px;color:var(--text2);line-height:1.6;margin-bottom:20px}
.m-acts{display:flex;gap:7px;justify-content:flex-end}
.m-cancel{padding:7px 14px;background:transparent;border:1px solid var(--border);color:var(--text2);font-size:13px;cursor:pointer;border-radius:2px;font-family:'DM Sans',sans-serif;transition:all .15s}
.m-cancel:hover{border-color:var(--border2);color:var(--text)}
.m-ok{padding:7px 14px;border:none;font-size:13px;font-weight:600;cursor:pointer;border-radius:2px;font-family:'DM Sans',sans-serif;transition:background .15s}

/* Toast */
.toast{position:fixed;bottom:22px;right:22px;z-index:999;background:var(--surface);border:1px solid var(--border);padding:11px 16px;font-size:13px;display:flex;align-items:center;gap:9px;box-shadow:0 8px 32px rgba(0,0,0,.5);transform:translateY(70px);opacity:0;transition:all .3s cubic-bezier(.4,0,.2,1);max-width:300px}
.toast.show{transform:translateY(0);opacity:1}
.t-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}

/* Spinner */
.spinner{width:16px;height:16px;border:2px solid var(--border2);border-top-color:var(--accent);border-radius:50%;animation:spin .7s linear infinite;display:inline-block;vertical-align:middle;margin-right:6px}
@keyframes spin{to{transform:rotate(360deg)}}

@media(max-width:768px){.kpi-row{grid-template-columns:repeat(2,1fr)}.content{padding:12px}.topbar{padding:0 12px}.t-url{display:none}.ut th:nth-child(4),.ut td:nth-child(4),.ut th:nth-child(5),.ut td:nth-child(5){display:none}}
</style>
</head>
<body>

<!-- GATE -->
<div id="gate">
  <div class="gate-card">
    <div class="g-logo"><div class="g-mark">AP</div><span class="g-name">AutoPanel</span></div>
    <div style="text-align:center"><div class="g-badge">🔒 Beheerportaal</div></div>
    <div class="g-title">Administrator toegang</div>
    <div class="g-sub">Uitsluitend toegankelijk voor beheerders van AutoPanel.</div>
    <div class="g-field"><label class="g-label">E-mailadres</label><input type="email" class="g-input" id="g-email" placeholder="admin@autopanel.nl" autocomplete="email"></div>
    <div class="g-field"><label class="g-label">Wachtwoord</label><input type="password" class="g-input" id="g-pwd" placeholder="••••••••" autocomplete="current-password"></div>
    <div class="g-err" id="g-err">Toegang geweigerd. Controleer je gegevens.</div>
    <button class="g-btn" id="g-btn" onclick="doAdminLogin()">Toegang verkrijgen</button>
    <div class="g-foot">admin.autopanel.nl</div>
  </div>
</div>

<!-- PANEL -->
<div id="panel">
  <div class="topbar">
    <div class="t-logo"><div class="t-mark">AP</div><span class="t-name">AutoPanel</span><span class="t-badge">Admin</span><span class="t-url">admin.autopanel.nl</span></div>
    <div class="t-sp"></div>
    <div class="t-user">
      <div class="t-av" id="t-av">A</div>
      <span class="t-uname" id="t-uname">Beheerder</span>
      <button class="t-out" onclick="doLogout()">Uitloggen</button>
    </div>
  </div>

  <div class="content">
    <div class="kpi-row" id="kpi-row"></div>

    <div class="panel">
      <div class="ph">
        <div class="pt">Gebruikersaanvragen</div>
        <div class="search-wrap">
          <div class="sbox"><span style="color:var(--text3);font-size:13px">⌕</span><input type="text" placeholder="Naam, bedrijf, e-mail…" oninput="filterUsers(this.value)"></div>
          <div style="display:flex;gap:5px;flex-wrap:wrap">
            <div class="pill active" onclick="setFilter('alle',this)">Alle</div>
            <div class="pill" onclick="setFilter('pending',this)">In afwachting</div>
            <div class="pill" onclick="setFilter('approved',this)">Goedgekeurd</div>
            <div class="pill" onclick="setFilter('revoked',this)">Ingetrokken</div>
          </div>
        </div>
      </div>
      <div class="tw"><table class="ut"><thead><tr><th>Naam</th><th>Bedrijf</th><th>E-mail</th><th>Type</th><th>Aangevraagd</th><th>Status</th><th>Acties</th></tr></thead><tbody id="utbody"></tbody></table></div>
    </div>

    <div class="panel">
      <div class="ph"><div class="pt">Activiteitslog</div><div class="pm" id="log-count"></div></div>
      <div class="tw"><table class="ut"><thead><tr><th>Tijdstip</th><th>Actie</th><th>Gebruiker</th></tr></thead><tbody id="logtbody"></tbody></table></div>
    </div>
  </div>
</div>

<!-- Modal -->
<div class="mback" id="mback">
  <div class="modal">
    <div class="m-title" id="m-title"></div>
    <div class="m-text" id="m-text"></div>
    <div class="m-acts">
      <button class="m-cancel" onclick="closeModal()">Annuleren</button>
      <button class="m-ok" id="m-ok">Bevestigen</button>
    </div>
  </div>
</div>

<!-- Toast -->
<div class="toast" id="toast"><div class="t-dot" id="t-dot"></div><span id="t-txt"></span></div>

<script>
// ─── Supabase init ────────────────────────────────────────────
const SUPABASE_URL      = 'https://jouwprojectid.supabase.co'; // ← aanpassen
const SUPABASE_ANON_KEY = 'jouw-anon-key';                     // ← aanpassen
const { createClient } = supabase;
const sb = createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

let allUsers = [], filterStatus = 'alle', searchQ = '', pendingAct = null;

const typeLabels = {dealer:'Dealer',garage:'Garage',inkoper:'Inkoper',veiling:'Veiling',ander:'Anders'};

// ─── Admin login ──────────────────────────────────────────────
async function doAdminLogin() {
  const email = document.getElementById('g-email').value.trim();
  const pwd   = document.getElementById('g-pwd').value;
  const err   = document.getElementById('g-err');
  const btn   = document.getElementById('g-btn');
  err.classList.remove('show');
  btn.disabled = true;
  btn.innerHTML = '<span class="spinner"></span> Bezig…';

  try {
    const { data, error } = await sb.auth.signInWithPassword({ email, password: pwd });
    if (error) throw error;

    // Controleer admin rol
    const { data: profile, error: pe } = await sb
      .from('profiles').select('role,status,first_name,last_name').eq('id', data.user.id).single();
    if (pe || profile.role !== 'admin') {
      await sb.auth.signOut();
      throw new Error('Geen adminrechten');
    }

    // Toon panel
    document.getElementById('gate').style.display = 'none';
    document.getElementById('panel').style.display = 'block';
    const initials = (profile.first_name?.[0]||'A').toUpperCase();
    document.getElementById('t-av').textContent = initials;
    document.getElementById('t-uname').textContent = profile.first_name + ' ' + profile.last_name;
    await loadAll();

  } catch(e) {
    err.classList.add('show');
    document.getElementById('g-pwd').value = '';
  } finally {
    btn.disabled = false;
    btn.textContent = 'Toegang verkrijgen';
  }
}

async function doLogout() {
  await sb.auth.signOut();
  location.reload();
}

// ─── Data laden ───────────────────────────────────────────────
async function loadAll() {
  await Promise.all([loadUsers(), loadLog()]);
}

async function loadUsers() {
  const { data, error } = await sb
    .from('v_users')
    .select('*')
    .order('aangevraagd_op', { ascending: false });
  if (error) { console.error(error); return; }
  allUsers = data || [];
  renderKpis();
  renderUsers();
}

async function loadLog() {
  const { data } = await sb
    .from('admin_log')
    .select('*')
    .order('aangemaakt_op', { ascending: false })
    .limit(20);
  renderLog(data || []);
}

// ─── Render KPIs ─────────────────────────────────────────────
function renderKpis() {
  const pending  = allUsers.filter(u=>u.status==='pending').length;
  const approved = allUsers.filter(u=>u.status==='approved').length;
  const revoked  = allUsers.filter(u=>u.status==='revoked').length;
  document.getElementById('kpi-row').innerHTML = `
    <div class="kpi y"><div class="kpi-lbl">In afwachting</div><div class="kpi-val">${pending}</div><div class="kpi-sub">Wachten op beoordeling</div></div>
    <div class="kpi g"><div class="kpi-lbl">Goedgekeurd</div><div class="kpi-val">${approved}</div><div class="kpi-sub">Actieve gebruikers</div></div>
    <div class="kpi r"><div class="kpi-lbl">Ingetrokken</div><div class="kpi-val">${revoked}</div><div class="kpi-sub">Toegang geblokkeerd</div></div>
    <div class="kpi b"><div class="kpi-lbl">Totaal</div><div class="kpi-val">${allUsers.length}</div><div class="kpi-sub">Alle aanvragen</div></div>`;
}

// ─── Render users ─────────────────────────────────────────────
function getFiltered() {
  return allUsers.filter(u => {
    const ms = filterStatus === 'alle' || u.status === filterStatus;
    const q  = searchQ.toLowerCase();
    const mt = !q || (u.full_name||'').toLowerCase().includes(q) ||
               (u.company||'').toLowerCase().includes(q) ||
               (u.email||'').toLowerCase().includes(q);
    return ms && mt;
  });
}

function badge(s) {
  const map = {pending:'bp',approved:'ba',revoked:'br'};
  const lbl = {pending:'In afwachting',approved:'Goedgekeurd',revoked:'Ingetrokken'};
  return `<span class="badge ${map[s]||'bp'}">${lbl[s]||s}</span>`;
}

function fmtDate(d) {
  if (!d) return '—';
  return new Date(d).toLocaleDateString('nl-NL', {day:'2-digit',month:'2-digit',year:'numeric'});
}

function renderUsers() {
  const list = getFiltered();
  const tb = document.getElementById('utbody');
  if (!list.length) {
    tb.innerHTML = `<tr><td colspan="7"><div class="empty">Geen gebruikers gevonden</div></td></tr>`;
    return;
  }
  tb.innerHTML = list.map(u => `
    <tr>
      <td><span class="td-name">${u.full_name||'—'}</span></td>
      <td><span class="td-co">${u.company||'—'}</span></td>
      <td style="font-size:12.5px">${u.email}</td>
      <td style="font-size:12px;color:var(--text2)">${typeLabels[u.company_type]||u.company_type||'—'}</td>
      <td><span class="td-date">${fmtDate(u.aangevraagd_op)}</span></td>
      <td>${badge(u.status)}</td>
      <td>
        <div class="acts">
          ${u.status!=='approved' ? `<button class="b-app" onclick="confirm_('${u.id}','approve','${(u.full_name||'').replace(/'/g,"\\'")}')">✓ Goedkeuren</button>` : ''}
          ${u.status==='approved'  ? `<button class="b-rev" onclick="confirm_('${u.id}','revoke','${(u.full_name||'').replace(/'/g,"\\'")}')">✕ Intrekken</button>` : ''}
          ${u.status==='revoked'   ? `<button class="b-app" onclick="confirm_('${u.id}','approve','${(u.full_name||'').replace(/'/g,"\\'")}')">↺ Herstellen</button>` : ''}
          <button class="b-del" onclick="confirm_('${u.id}','delete','${(u.full_name||'').replace(/'/g,"\\'")}')">🗑</button>
        </div>
      </td>
    </tr>`).join('');
}

function renderLog(log) {
  document.getElementById('log-count').textContent = `${log.length} acties`;
  const actionColors = {Goedgekeurd:'var(--green)',Ingetrokken:'var(--red)',Verwijderd:'var(--orange)'};
  document.getElementById('logtbody').innerHTML = log.map(l => `
    <tr>
      <td class="td-date">${new Date(l.aangemaakt_op).toLocaleString('nl-NL',{day:'2-digit',month:'2-digit',year:'numeric',hour:'2-digit',minute:'2-digit'})}</td>
      <td><span style="font-weight:600;color:${actionColors[l.actie]||'var(--text)'}">${l.actie}</span></td>
      <td>${l.doel_naam||'—'}</td>
    </tr>`).join('') || `<tr><td colspan="3"><div class="empty">Nog geen acties</div></td></tr>`;
}

// ─── Filters ─────────────────────────────────────────────────
function filterUsers(q) { searchQ = q; renderUsers(); }
function setFilter(s, el) {
  filterStatus = s;
  document.querySelectorAll('.pill').forEach(p => p.classList.remove('active'));
  el.classList.add('active');
  renderUsers();
}

// ─── Actions ─────────────────────────────────────────────────
function confirm_(id, action, name) {
  const titles = {approve:'Toegang goedkeuren', revoke:'Toegang intrekken', delete:'Gebruiker verwijderen'};
  const texts  = {
    approve:`Wil je <strong>${name}</strong> goedkeuren? Ze ontvangen een e-mail en kunnen direct inloggen.`,
    revoke: `Wil je de toegang van <strong>${name}</strong> intrekken? Ze kunnen niet meer inloggen.`,
    delete: `Wil je <strong>${name}</strong> definitief verwijderen? Dit kan niet ongedaan worden gemaakt.`,
  };
  document.getElementById('m-title').textContent = titles[action];
  document.getElementById('m-text').innerHTML = texts[action];
  const btn = document.getElementById('m-ok');
  btn.textContent = action==='approve' ? 'Goedkeuren' : action==='revoke' ? 'Intrekken' : 'Verwijderen';
  btn.style.background = action==='approve' ? 'var(--green)' : 'var(--red)';
  btn.style.color = action==='approve' ? '#000' : '#fff';
  pendingAct = { id, action, name };
  document.getElementById('mback').classList.add('open');
}

document.getElementById('m-ok').addEventListener('click', async () => {
  if (!pendingAct) return;
  const { id, action, name } = pendingAct;
  closeModal();

  try {
    if (action === 'approve' || action === 'revoke') {
      const status = action === 'approve' ? 'approved' : 'revoked';
      const { error } = await sb.from('profiles').update({ status }).eq('id', id);
      if (error) throw error;
      const actLabel = action === 'approve' ? 'Goedgekeurd' : 'Ingetrokken';
      await sb.from('admin_log').insert({ actie: actLabel, doel_user: id, doel_naam: name });
      showToast(action==='approve' ? `✓ ${name} heeft toegang` : `✕ Toegang ingetrokken voor ${name}`, action==='approve'?'var(--green)':'var(--red)');
    } else if (action === 'delete') {
      const { error } = await sb.from('profiles').delete().eq('id', id);
      if (error) throw error;
      await sb.from('admin_log').insert({ actie: 'Verwijderd', doel_user: null, doel_naam: name });
      showToast(`🗑 ${name} verwijderd`, 'var(--orange)');
    }
    await loadAll();
  } catch(e) {
    showToast('Fout: ' + e.message, 'var(--red)');
  }
  pendingAct = null;
});

function closeModal() {
  document.getElementById('mback').classList.remove('open');
  pendingAct = null;
}
document.getElementById('mback').addEventListener('click', e => { if(e.target===e.currentTarget) closeModal(); });

// ─── Toast ────────────────────────────────────────────────────
function showToast(msg, color='var(--green)') {
  document.getElementById('t-txt').textContent = msg;
  document.getElementById('t-dot').style.background = color;
  const t = document.getElementById('toast');
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 3200);
}

// Enter key on gate
document.addEventListener('keydown', e => {
  if (e.key==='Enter' && document.getElementById('gate').style.display!=='none') doAdminLogin();
});

// Check if already logged in as admin
(async () => {
  const { data: { session } } = await sb.auth.getSession();
  if (session) {
    const { data: p } = await sb.from('profiles').select('role,first_name,last_name').eq('id',session.user.id).single();
    if (p?.role==='admin') {
      document.getElementById('gate').style.display='none';
      document.getElementById('panel').style.display='block';
      document.getElementById('t-av').textContent=(p.first_name?.[0]||'A').toUpperCase();
      document.getElementById('t-uname').textContent=p.first_name+' '+p.last_name;
      await loadAll();
    }
  }
})();
</script>
